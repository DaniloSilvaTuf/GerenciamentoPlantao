<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GerenciamentoPlantao</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GerenciamentoPlantao.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-dark text-white p-3" style="width: 260px; min-height: 100vh;">

            <h4 class="text-center mb-4">
                <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">
                    <i class="bi bi-hospital"></i>
                    Plantão
                </a>
            </h4>

            <hr class="text-secondary" />

            <ul class="nav flex-column gap-1">

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Acionamentos" asp-action="Index">
                        <i class="bi bi-telephone"></i> Acionamentos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Estabelecimentos" asp-action="Index">
                        <i class="bi bi-building"></i> Estabelecimentos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Setores" asp-action="Index">
                        <i class="bi bi-diagram-3"></i> Setores
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Departamentos" asp-action="Index">
                        <i class="bi bi-collection"></i> Departamentos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Usuarios" asp-action="Index">
                        <i class="bi bi-people"></i> Usuários
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Canais" asp-action="Index">
                        <i class="bi bi-chat-dots"></i> Canais
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="CategoriasAcionamento" asp-action="Index">
                        <i class="bi bi-tags"></i> Categorias
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-controller="Solucoes" asp-action="Index">
                        <i class="bi bi-check2-circle"></i> Soluções
                    </a>
                </li>

            </ul>

        </div>

        <!-- CONTEÚDO -->
        <div class="flex-grow-1">

            <!-- TOP BAR -->
            <nav class="navbar navbar-light bg-white border-bottom px-3">
                <span class="navbar-brand mb-0 h1">
                    @ViewData["Title"]
                </span>
            </nav>

            <!-- MAIN -->
            <div class="container mt-3">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>

            <!-- FOOTER -->
            <footer class="border-top footer text-muted mt-auto">
                <div class="container py-2">
                    &copy; 2026 - GerenciamentoPlantao
                </div>
            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>