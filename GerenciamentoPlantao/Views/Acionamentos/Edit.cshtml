@model GerenciamentoPlantao.Models.ViewModels.EditarAcionamentoViewModel

@{
    ViewData["Title"] = "Editar Acionamento";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-pencil-square"></i>
                Editar Acionamento
            </h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input asp-for="Id" type="hidden" />

                <!-- Data -->
                <div class="mb-3">
                    <label asp-for="DataAcionamento" class="form-label fw-bold">
                        Data do Acionamento
                    </label>

                    <input asp-for="DataAcionamento"
                           type="datetime-local"
                           class="form-control form-control-lg" />

                    <span asp-validation-for="DataAcionamento" class="text-danger"></span>
                </div>

                <!-- Plantonista / Canal -->
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="UsuarioId" class="form-label fw-bold">
                            Plantonista
                        </label>

                        <select asp-for="UsuarioId"
                                asp-items="Model.Plantonista"
                                class="form-select">
                            <option value="">Selecione...</option>
                        </select>

                        <span asp-validation-for="UsuarioId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CanalId" class="form-label fw-bold">
                            Canal de Atendimento
                        </label>

                        <select asp-for="CanalId"
                                asp-items="Model.Canal"
                                class="form-select">
                            <option value="">Selecione...</option>
                        </select>

                        <span asp-validation-for="CanalId" class="text-danger"></span>
                    </div>

                </div>

                <!-- Acionador / Atendimento -->
                <div class="row">

                    <div class="col-md-8 mb-3">
                        <label asp-for="Acionador" class="form-label fw-bold">
                            Acionador
                        </label>

                        <input asp-for="Acionador"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="Acionador" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="NrAtendimento" class="form-label fw-bold">
                            Nº Atendimento
                        </label>

                        <input asp-for="NrAtendimento"
                               class="form-control form-control-lg" />

                        <span asp-validation-for="NrAtendimento" class="text-danger"></span>
                    </div>

                </div>

                <!-- Estabelecimento -->
                <div class="mb-3">
                    <label asp-for="EstabelecimentoId" class="form-label fw-bold">
                        Estabelecimento
                    </label>

                    <select asp-for="EstabelecimentoId"
                            asp-items="Model.Estabelecimento"
                            class="form-select">
                        <option value="">Selecione...</option>
                    </select>

                    <span asp-validation-for="EstabelecimentoId" class="text-danger"></span>
                </div>

                <!-- Setor / Categoria -->
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="SetorId" class="form-label fw-bold">
                            Setor
                        </label>

                        <select asp-for="SetorId"
                                asp-items="Model.Setor"
                                class="form-select">
                            <option value="">Selecione...</option>
                        </select>

                        <span asp-validation-for="SetorId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoriaId" class="form-label fw-bold">
                            Categoria
                        </label>

                        <select asp-for="CategoriaId"
                                asp-items="Model.Categoria"
                                class="form-select">
                            <option value="">Selecione...</option>
                        </select>

                        <span asp-validation-for="CategoriaId" class="text-danger"></span>
                    </div>

                </div>

                <!-- Solução -->
                <div class="mb-3">
                    <label asp-for="SolucaoId" class="form-label fw-bold">
                        Solução
                    </label>

                    <select asp-for="SolucaoId"
                            asp-items="Model.Solucao"
                            class="form-select">
                        <option value="">Selecione...</option>
                    </select>

                    <span asp-validation-for="SolucaoId" class="text-danger"></span>
                </div>

                <!-- Apoio -->
                <div class="mb-3">

                    <label class="form-label fw-bold d-block">
                        Apoio
                    </label>

                    <div class="form-check">
                        <input asp-for="Apoio"
                               class="form-check-input" />
                        <label asp-for="Apoio"
                               class="form-check-label">
                            Necessitou de apoio
                        </label>
                    </div>

                </div>

                <!-- Observações -->
                <div class="mb-3">

                    <label asp-for="Observacao" class="form-label fw-bold">
                        Observações
                    </label>

                    <textarea asp-for="Observacao"
                              rows="4"
                              class="form-control"></textarea>

                    <span asp-validation-for="Observacao" class="text-danger"></span>

                </div>

                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy-fill"></i>
                        Salvar
                    </button>

                    <button type="button"
                            class="btn btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#modalExcluir">
                        <i class="bi bi-trash-fill"></i>
                        Excluir
                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Voltar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<!-- Modal de Exclusão -->
<div class="modal fade"
     id="modalExcluir"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header bg-danger text-white">

                <h5 class="modal-title">
                    Confirmar Exclusão
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p class="mb-0">
                    Tem certeza que deseja excluir este acionamento?
                </p>

                <small class="text-danger">
                    Esta ação não poderá ser desfeita.
                </small>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form asp-action="Delete"
                      asp-route-id="@Model.Id"
                      method="post">

                    <button type="submit"
                            class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i>
                        Excluir
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}