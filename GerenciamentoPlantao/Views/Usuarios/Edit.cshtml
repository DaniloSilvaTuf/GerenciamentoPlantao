@model GerenciamentoPlantao.Models.ViewModels.EditarUsuarioViewModel

@{
    ViewData["Title"] = "Editar Usuário";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-person-plus-fill"></i> Editar Usuário
            </h3>
        </div>

        <div class="card-body">
            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label asp-for="DescNome" class="form-label fw-bold"> Nome </label>
                    <input asp-for="DescNome" class="form-control form-control-lg"/>
                    <span asp-validation-for="DescNome" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NmUsuario" class="form-label fw-bold"> Nome de Usuário </label>
                        <input asp-for="NmUsuario" class="form-control form-control-lg" readonly/>
                        <span class="form-text"> O nome de usuário não pode ser alterado. </span>
                        <span asp-validation-for="NmUsuario" class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DepartamentoId" class="form-label fw-bold"> Departamento </label>
                        <select asp-for="DepartamentoId" asp-items="Model.Departamentos" class="form-select">
                            <option value=""> Selecione um departamento </option>
                        </select>
                        <span asp-validation-for="DepartamentoId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-bold"> E-mail </label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg"/>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefone" class="form-label fw-bold"> Telefone </label>
                        <input asp-for="Telefone" class="form-control form-control-lg"/>
                        <span asp-validation-for="Telefone" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="Plantonista" class="form-check-input" />
                        <label asp-for="Plantonista" class="form-check-label fw-bold"> Usuário Plantonista </label>
                    </div>
                </div>
                    <div class="mb-3">
                        @if (Model.Ativo)
                        {
                            <span class="badge bg-success fs-6">
                                <i class="bi bi-check-circle-fill"></i> Ativo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">
                                <i class="bi bi-x-circle-fill"></i> Inativo
                            </span>
                        }

                    </div>
                    <div class="d-flex gap-2">

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy-fill"></i> Salvar

                        </button>

                        @if (Model.Ativo)
                        {
                            <button asp-action="Inativar" asp-route-id="@Model.Id" formmethod="post" class="btn btn-danger">
                                <i class="bi bi-ban-fill"></i> Inativar
                            </button>
                        }
                        else
                        {
                            <button asp-action="Ativar" asp-route-id="@Model.Id" formmethod="post" class="btn btn-success">
                                <i class="bi bi-check-circle-fill"></i> Ativar
                            </button>
                        }

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Remove espaços e deixa o usuário sempre em minúsculo
        document.getElementById("NmUsuario").addEventListener("input", function() {
            this.value = this.value
                .toLowerCase()
                .replace(/\s/g, '');
        });

        // Máscara de telefone
        document.getElementById("Telefone").addEventListener("input", function() {

            let valor = this.value.replace(/\D/g, '');

            if (valor.length > 11)
                valor = valor.substring(0, 11);

            if (valor.length > 6)
                valor = valor.replace(/^(\d{2})(\d{5})(\d{0,4}).*/, '($1) $2-$3');
            else if (valor.length > 2)
                valor = valor.replace(/^(\d{2})(\d+)/, '($1) $2');

            this.value = valor;

        });
    </script>
}