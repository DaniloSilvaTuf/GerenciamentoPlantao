@model IEnumerable<GerenciamentoPlantao.Models.Setor>

@{
    ViewData["Title"] = "Setores";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">
                <i class="bi bi-diagram-3"></i> Setores
            </h3>

            <a asp-action="Create" class="btn btn-light">
                <i class="bi bi-plus-circle"></i> Cadastrar Novo
            </a>
        </div>

        <div class="card-body">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Nome)</th>
                        <th>Estabelecimento</th>
                        <th>Status</th>

                        <th class="text-end"> Ações </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nome</td>
                            <td>@item.Estabelecimento?.Nome</td>
                            <td>
                                @if (item.Ativo)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle-fill"></i> Ativo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle-fill"></i> Inativo
                                    </span>
                                }
                            </td>

                            <td class="text-end">

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">

                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>