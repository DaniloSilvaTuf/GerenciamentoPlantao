@model GerenciamentoPlantao.Models.ViewModels.SolucaoFormViewModel

@{
    ViewData["Title"] = "Cadastrar Solução";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-check2-circle"></i> Cadastrar Solução
            </h3>
        </div>

        <div class="card-body">
            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-bold"></label>

                    <input asp-for="Nome"
                           class="form-control form-control-lg"
                           placeholder="Digite o nome da solução" />

                    <span asp-validation-for="Nome"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="DepartamentoId"
                           class="form-label fw-bold">
                        Estabelecimento
                    </label>

                    <select asp-for="DepartamentoId"
                            asp-items="Model.Departamentos"
                            class="form-select">

                        <option value="">
                            Selecione um departamento
                        </option>

                    </select>

                    <span asp-validation-for="DepartamentoId"
                          class="text-danger">
                    </span>

                    <span asp-validation-for="DepartamentoId"
                          class="text-danger">
                    </span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-floppy-fill"></i> Salvar
                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}